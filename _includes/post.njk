---
layout: base.njk
---
<article class="blog-post">
  <a href="/blog/" class="blog-back">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
    Back to Blog
  </a>

  <header class="blog-post-header">
    <div class="blog-meta">{{ date | dateDisplay }} &middot; {{ author or "The Funders Team" }}</div>
    <h1>{{ title }}</h1>
    {% if tags %}
    <div class="blog-tags">
      {% for tag in tags %}
      <span>{{ tag }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </header>

  {% if thumbnail %}
  <div class="blog-post-image">
    <img src="{{ thumbnail }}" alt="{{ title }}">
  </div>
  {% endif %}

  <div class="blog-post-body">
    {{ content | safe }}
  </div>
</article>
